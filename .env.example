# Runtime bootstrap
AUTO_CLOUD_CONNECT=1
DVC_AUTO_PULL=0
CLOUD_PROVIDER=
DVC_REMOTE_NAME=origin
DVC_REMOTE_SUBPATH=dvc
INTERACTIVE_PROMPTS=1
WORKFORCE_PROMPT=1

# DVC remote buckets (set one provider-specific value, or use DVC_BUCKET)
DVC_BUCKET=
DVC_S3_BUCKET=
DVC_GS_BUCKET=
DVC_AZURE_CONTAINER=
AZURE_STORAGE_ACCOUNT=

# AWS
AWS_REGION=ap-south-1
AWS_PROFILE=default
ECR_REPOSITORY=workforce-mlops-app
EC2_USER=ubuntu

# MLflow
MLFLOW_TRACKING_URI= # Use public IP/DNS (not 0.0.0.0) e.g. http://<public-ip>:5000
MLFLOW_ALLOWED_HOSTS= # Comma-separated list for server (e.g. "<public-ip>,localhost,127.0.0.1")
MLFLOW_PUBLIC_HOST=
MLFLOW_TRACKING_URI_DEFAULT=
MLFLOW_TRACKING_URI_AWS=
MLFLOW_TRACKING_URI_GCP=
MLFLOW_TRACKING_URI_AZURE=
MLFLOW_EXPERIMENT_NAME=workforce-multitask

# Repo
GITHUB_REPO=<owner>/workforce-mlops
